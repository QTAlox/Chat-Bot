# ============================================================
#  Copie para .env e preencha — NUNCA envie o .env pro GitHub
# ============================================================

# === DISCORD (conta normal dedicada) ===
DISCORD_TOKEN=seu_token_de_usuario_aqui

# === PROVEDOR DE IA (groq ou ollama) ===
AI_PROVIDER=groq

# Groq — grátis em console.groq.com
GROQ_API_KEY=gsk_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — 100% local, instale em ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# === SERVIDORES E CANAIS ===
ALLOWED_GUILD_IDS=ID_DO_SEU_SERVIDOR
ALLOWED_CHANNEL_IDS=
IGNORED_CHANNEL_IDS=

# === COMPORTAMENTO ===
CONTEXT_WINDOW_SIZE=30
RESPONSE_DELAY_MIN=3
RESPONSE_DELAY_MAX=12
BASE_RESPONSE_CHANCE=15
ALWAYS_RESPOND_TO_NAME=true
PERSONA_NAME=Felipe

# === LOCALIZAÇÃO E HORÁRIO ===
# Cidade onde o Felipe "mora"
PERSONA_CITY=São Paulo
PERSONA_STATE=SP
PERSONA_COUNTRY=Brasil

# Fuso horário (lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Exemplos: America/Sao_Paulo | America/Manaus | America/Fortaleza | America/Belem
TIMEZONE=America/Sao_Paulo

# === ESTILO DE ESCRITA ===
# Nível de gírias: 0 = nenhuma | 5 = moderado | 10 = muito
SLANG_LEVEL=5

# Nível de formalidade: 0 = muito informal | 5 = neutro | 10 = formal
FORMALITY_LEVEL=2

# Frequência de "kkk/rsrs": 0 = nunca | 5 = às vezes | 10 = sempre
LAUGH_LEVEL=3

# === DONO DO BOT ===
# Seu user ID do Discord — só você pode mandar comandos no bot
# Para pegar: Discord → Configurações → Avançado → Modo desenvolvedor
# Depois clica com botão direito no seu perfil → Copiar ID
OWNER_ID=SEU_USER_ID_AQUI

# === BUSCA WEB ===
# Habilita busca antes de responder sobre músicas, filmes, etc.
WEB_SEARCH_ENABLED=true

# === SPOTIFY API (gratuito) ===
# Crie um app em: developer.spotify.com → Create App
# Copie o Client ID e Client Secret
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui
